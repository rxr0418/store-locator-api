# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-32-char-string

# Database (Railway/Render auto-provides DATABASE_URL in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/store_locator

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-to-something-random
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# Rate limiting (use memory:// for dev, redis://... for production)
RATE_LIMIT_STORAGE_URL=memory://

# Geocoding
GEOCODING_USER_AGENT=store-locator-app
